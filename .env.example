# Copy this file to .env and fill in real values before starting the stack.

# Zabbix API token
# Create in Zabbix: Administration → API tokens → Create API token
ZABBIX_TOKEN=replace-with-real-zabbix-api-token

# Grafana service account token
# Create in Grafana: Administration → Service accounts → Add service account token
GRAFANA_TOKEN=replace-with-real-grafana-service-account-token
