{
  "model": "google/gemini-2.0-flash-exp:free",
  "provider": "openai",
  "openai": {
    "base_url": "https://openrouter.ai/api/v1",
    "api_key": "your-openrouter-api-key-here"
  },
  "max_tokens": 4096,
  "temperature": 0.7,
  "mcp": [
    {
      "name": "zabbix",
      "type": "remote",
      "url": "http://localhost:8001/sse"
    },
    {
      "name": "grafana",
      "type": "remote",
      "url": "http://localhost:8002/sse"
    }
  ],
  "system_prompt": "You are an expert infrastructure engineer with access to Zabbix monitoring and Grafana dashboards via MCP servers. Use these tools to query host status, alerts, and performance data.",
  "tools": {
    "web_search": true,
    "file_system": true,
    "shell_execution": true
  }
}
